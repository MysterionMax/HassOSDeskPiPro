{
  "name": "DeskPi Pro Active Cooling (Fixed)",
  "version": "0.6d",
  "slug": "deskpipro",
  "description": "This adjusts the temp of DeskPi Pro by fan control",
  "arch": ["aarch64"],
  "startup": "services",
  "boot": "auto",
  "full_access": true,
  "ingress": true,
  "homeassistant_api": true,
  "devices": [
    "/dev/ttyUSB0:/dev/ttyUSB0:rwm",
    "/dev/ttyUSB1:/dev/ttyUSB1:rwm",
    "/dev/ttyUSB2:/dev/ttyUSB2:rwm",
    "/dev/ttyUSB3:/dev/ttyUSB3:rwm",
    "/dev/ttyUSB4:/dev/ttyUSB4:rwm"
  ],
  "options": {
    "CorF": "F",
    "LowRange": 90,
    "MediumRange": 115,
    "HighRange": 122,
    "QuietProfile": true,
    "SerialDevice": "/dev/ttyUSB0"
  },
  "schema": {
    "CorF": "str",
    "LowRange": "int(0,255)",
    "MediumRange": "int(0,255)",
    "HighRange": "int(0,255)",
    "QuietProfile": "bool",
    "SerialDevice": "str"
  }
}